{
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "type": "stat",
      "title": "Requests / second",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(rate(tiny_shop_http_requests_total[5m]))",
          "refId": "A"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 0,
        "y": 0
      }
    },
    {
      "type": "stat",
      "title": "HTTP error percentage",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "100 * sum(rate(tiny_shop_http_requests_total{status_code=~\"4..|5..\"}[5m])) / clamp_min(sum(rate(tiny_shop_http_requests_total[5m])), 0.000001)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 6,
        "y": 0
      }
    },
    {
      "type": "stat",
      "title": "Confirmed orders",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(tiny_shop_orders_confirmed_total)",
          "refId": "A"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 12,
        "y": 0
      }
    },
    {
      "type": "stat",
      "title": "Failed payments",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(tiny_shop_payments_failed_total)",
          "refId": "A"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 18,
        "y": 0
      }
    },
    {
      "type": "timeseries",
      "title": "Request rate by service",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum by (service) (rate(tiny_shop_http_requests_total[5m]))",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ],
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 0,
        "y": 8
      }
    },
    {
      "type": "timeseries",
      "title": "p95 latency by service and route",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, service, route) (rate(tiny_shop_http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "{{service}} {{route}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 12,
        "y": 8
      }
    },
    {
      "type": "timeseries",
      "title": "Inventory stock",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "tiny_shop_inventory_stock_quantity",
          "legendFormat": "{{sku}}",
          "refId": "A"
        }
      ],
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 0,
        "y": 17
      }
    },
    {
      "type": "timeseries",
      "title": "Payment outcomes",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "rate(tiny_shop_payments_succeeded_total[5m])",
          "legendFormat": "success",
          "refId": "A"
        },
        {
          "expr": "sum(rate(tiny_shop_payments_failed_total[5m]))",
          "legendFormat": "failed",
          "refId": "B"
        }
      ],
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 12,
        "y": 17
      }
    },
    {
      "type": "timeseries",
      "title": "Active alerts",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum by (alertname, severity) (ALERTS{alertstate=\"firing\"})",
          "legendFormat": "{{alertname}} ({{severity}})",
          "refId": "A"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 26
      }
    },
    {
      "type": "logs",
      "title": "Recent Tiny Shop logs",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "expr": "{project=\"tiny-shop\"} | json",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "sortOrder": "Descending"
      },
      "gridPos": {
        "h": 12,
        "w": 12,
        "x": 12,
        "y": 26
      }
    },
    {
      "type": "logs",
      "title": "Errors with trace links",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "expr": "{project=\"tiny-shop\",level=~\"ERROR|CRITICAL\"} | json",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "wrapLogMessage": true,
        "enableLogDetails": true,
        "sortOrder": "Descending"
      },
      "gridPos": {
        "h": 12,
        "w": 24,
        "x": 0,
        "y": 38
      }
    }
  ],
  "refresh": "5s",
  "schemaVersion": 39,
  "tags": [
    "tiny-shop",
    "observability"
  ],
  "templating": {
    "list": []
  },
  "time": {
    "from": "now-30m",
    "to": "now"
  },
  "timezone": "browser",
  "title": "Tiny Shop Overview",
  "uid": "tiny-shop-overview",
  "version": 2
}
